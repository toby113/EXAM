# 環境變數設定
# 複製此檔案為 .env 並填入實際值

# 伺服器埠號（預設 3000）
PORT=3000

# 管理員 API 金鑰（設定後，後台管理 API 需在 Header 帶入 x-api-key）
# 請使用隨機字串，例如：openssl rand -hex 32
# 留空則不啟用金鑰驗證（適合本地開發）
ADMIN_API_KEY=

# 允許的 CORS 來源（預設 http://localhost:3000）
ALLOWED_ORIGIN=http://localhost:3000

# ── LLM 出題功能 ──────────────────────────────────────────────────────────────
# 預設使用的 LLM 提供者：openai / gemini / claude
LLM_PROVIDER=openai

# OpenAI API 金鑰（https://platform.openai.com/api-keys）
OPENAI_API_KEY=

# Google Gemini API 金鑰（https://aistudio.google.com/app/apikey）
GEMINI_API_KEY=

# Anthropic Claude API 金鑰（https://console.anthropic.com/）
ANTHROPIC_API_KEY=
